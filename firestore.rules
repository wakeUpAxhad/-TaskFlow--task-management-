rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Column Validation
    function isValidColumn(data) {
      return data.keys().hasAll(['title', 'position', 'ownerId']) 
             && data.keys().size() == 3
             && data.title is string && data.title.size() <= 100
             && data.position is int
             && data.ownerId == request.auth.uid;
    }

    match /columns/{columnId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidColumn(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) 
                    && isValidColumn(request.resource.data)
                    && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isOwner(resource.data.ownerId);
    }

    // Task Validation
    function isValidTask(data) {
      return data.keys().hasAll(['content', 'position', 'columnId', 'ownerId', 'createdAt', 'updatedAt']) 
             && data.keys().size() == 6
             && data.content is string && data.content.size() <= 5000
             && data.position is int
             && data.columnId is string
             && data.ownerId == request.auth.uid
             && data.createdAt == request.time || data.createdAt == resource.data.createdAt
             && data.updatedAt == request.time;
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidTask(request.resource.data);
      allow update: if isOwner(resource.data.ownerId)
                    && isValidTask(request.resource.data)
                    && request.resource.data.ownerId == resource.data.ownerId
                    && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(resource.data.ownerId);
    }
  }
}
